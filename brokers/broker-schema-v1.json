{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Broker Spec v1",
  "description": "描述一家卷商如何被本系統整合（authentication、endpoints、capabilities）。",
  "type": "object",
  "required": [
    "id", "version", "display_name", "country",
    "integration", "auth", "environments", "capabilities"
  ],
  "additionalProperties": false,

  "properties": {
    "$schema":      { "type": "string" },
    "id":           { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
    "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "country":      { "type": "string", "minLength": 2, "maxLength": 8 },
    "website":      { "type": "string", "format": "uri" },

    "integration": {
      "type": "object",
      "required": ["type", "client_class"],
      "additionalProperties": false,
      "properties": {
        "type":         { "enum": ["rest", "sdk"] },
        "client_class": { "type": "string", "minLength": 1 },
        "sdk_package":  { "type": "string" }
      }
    },

    "auth": {
      "type": "object",
      "required": ["method", "required_env"],
      "properties": {
        "method": {
          "enum": [
            "api_key_secret",
            "oauth_bearer",
            "oauth_refresh",
            "session_login",
            "sdk_login"
          ]
        },
        "required_env":      { "type": "array", "items": { "type": "string" } },
        "required_env_live": { "type": "array", "items": { "type": "string" } },
        "header_template":   { "type": "object" },
        "session_endpoint":  { "type": "string" },
        "session_ttl_hours": { "type": "integer", "minimum": 1 }
      }
    },

    "environments": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object"
      }
    },

    "market_data": {
      "type": "object",
      "properties": {
        "data_url":             { "type": "string" },
        "latest_bars_endpoint": { "type": "string" },
        "calendar_endpoint":    { "type": "string" },
        "clock_endpoint":       { "type": "string" }
      }
    },

    "endpoints": {
      "type": "object",
      "properties": {
        "account":      { "type": "string" },
        "positions":    { "type": "string" },
        "orders":       { "type": "string" },
        "order_by_id":  { "type": "string" },
        "cancel_all":   { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },

    "capabilities": {
      "type": "object",
      "required": ["asset_classes", "order_types", "time_in_force"],
      "properties": {
        "fractional_shares":   { "type": "boolean" },
        "asset_classes":       { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "order_types":         { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "time_in_force":       { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "extended_hours":      { "type": "boolean" },
        "min_order_value_usd": { "type": "number", "minimum": 0 },
        "commission_per_trade":{ "type": "number", "minimum": 0 }
      }
    },

    "market": {
      "type": "object",
      "properties": {
        "timezone":   { "type": "string" },
        "open_time":  { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
        "close_time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
        "currency":   { "type": "string" }
      }
    },

    "rate_limits": {
      "type": "object",
      "properties": {
        "requests_per_minute": { "type": "integer", "minimum": 1 },
        "orders_per_second":   { "type": "number",  "minimum": 0 }
      }
    }
  }
}
