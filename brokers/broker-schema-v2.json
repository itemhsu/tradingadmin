{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Broker Spec v2",
  "description": "v1 + 宣告式對應表（request/response/value_maps），讓通用 RestBrokerClient 不寫 Python 即可整合 REST 券商。client_class 變選填：缺省即用通用引擎。",
  "type": "object",
  "required": [
    "id", "version", "display_name", "country",
    "integration", "auth", "environments", "capabilities"
  ],
  "additionalProperties": false,

  "properties": {
    "$schema":      { "type": "string" },
    "id":           { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
    "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "country":      { "type": "string", "minLength": 2, "maxLength": 8 },
    "website":      { "type": "string", "format": "uri" },

    "integration": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type":         { "enum": ["rest", "sdk"] },
        "client_class": { "type": "string", "minLength": 1 },
        "sdk_package":  { "type": "string" }
      }
    },

    "auth": {
      "type": "object",
      "required": ["method", "required_env"],
      "properties": {
        "method": {
          "enum": [
            "api_key_secret",
            "bearer_token",
            "oauth_bearer",
            "oauth_refresh",
            "session_login",
            "sdk_login"
          ]
        },
        "required_env":      { "type": "array", "items": { "type": "string" } },
        "required_env_live": { "type": "array", "items": { "type": "string" } },
        "header_template":   { "type": "object" },
        "session_endpoint":  { "type": "string" },
        "session_ttl_hours": { "type": "integer", "minimum": 1 }
      }
    },

    "environments": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "object" }
    },

    "market_data": {
      "type": "object",
      "properties": {
        "data_url":             { "type": "string" },
        "latest_bars_endpoint": { "type": "string" },
        "quotes_endpoint":      { "type": "string" },
        "calendar_endpoint":    { "type": "string" },
        "clock_endpoint":       { "type": "string" }
      }
    },

    "endpoints": {
      "type": "object",
      "properties": {
        "account":      { "type": "string" },
        "balances":     { "type": "string" },
        "positions":    { "type": "string" },
        "orders":       { "type": "string" },
        "order_by_id":  { "type": "string" },
        "cancel_all":   { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },

    "request": {
      "type": "object",
      "description": "下單請求如何組裝（通用名 → 券商欄位名）。",
      "required": ["encoding", "field_map"],
      "additionalProperties": false,
      "properties": {
        "encoding":  { "enum": ["json", "form"] },
        "field_map": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        },
        "constants": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      }
    },

    "response": {
      "type": "object",
      "description": "如何從回應 JSON 取值（點號路徑，list 用 a.b[] 取容器後正規化）。",
      "additionalProperties": false,
      "properties": {
        "order_id_path":     { "type": "string" },
        "order_status_path": { "type": "string" },
        "positions_path":    { "type": "string" },
        "quote_list_path":   { "type": "string" },
        "quote_symbol_field":{ "type": "string" },
        "quote_price_field": { "type": "string" },
        "balance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nav":          { "type": "string" },
            "cash":         { "type": "string" },
            "buying_power": { "type": "string" }
          }
        },
        "position_fields": {
          "type": "object",
          "description": "持倉欄位名對應（通用名 → 券商欄位名）。",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "value_maps": {
      "type": "object",
      "description": "枚舉值翻譯（如 side/time_in_force 的通用值 → 券商值）。",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },

    "capabilities": {
      "type": "object",
      "required": ["asset_classes", "order_types", "time_in_force"],
      "properties": {
        "fractional_shares":   { "type": "boolean" },
        "asset_classes":       { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "order_types":         { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "time_in_force":       { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "extended_hours":      { "type": "boolean" },
        "min_order_value_usd": { "type": "number", "minimum": 0 },
        "commission_per_trade":{ "type": "number", "minimum": 0 }
      }
    },

    "market": {
      "type": "object",
      "properties": {
        "timezone":   { "type": "string" },
        "open_time":  { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
        "close_time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
        "currency":   { "type": "string" }
      }
    },

    "rate_limits": {
      "type": "object",
      "properties": {
        "requests_per_minute": { "type": "integer", "minimum": 1 },
        "orders_per_second":   { "type": "number",  "minimum": 0 }
      }
    }
  }
}
