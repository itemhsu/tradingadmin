{
  "$schema": "broker-schema-v2.json",
  "id": "tradier",
  "version": "1.0",
  "display_name": "Tradier Brokerage",
  "country": "US",
  "website": "https://tradier.com",

  "integration": {
    "type": "rest"
  },

  "auth": {
    "method": "bearer_token",
    "required_env": ["{PREFIX}_API_KEY", "{PREFIX}_ACCOUNT_ID"],
    "header_template": {
      "Authorization": "Bearer {api_key}"
    }
  },

  "environments": {
    "sandbox": { "base_url": "https://sandbox.tradier.com/v1" },
    "live":    { "base_url": "https://api.tradier.com/v1" }
  },

  "market_data": {
    "quotes_endpoint":   "/markets/quotes",
    "clock_endpoint":    "/markets/clock",
    "calendar_endpoint": "/markets/calendar"
  },

  "endpoints": {
    "balances":    "/accounts/{account_id}/balances",
    "positions":   "/accounts/{account_id}/positions",
    "orders":      "/accounts/{account_id}/orders",
    "order_by_id": "/accounts/{account_id}/orders/{order_id}"
  },

  "request": {
    "encoding": "form",
    "field_map": {
      "symbol":        "symbol",
      "qty":           "quantity",
      "side":          "side",
      "order_type":    "type",
      "time_in_force": "duration"
    },
    "constants": { "class": "equity" }
  },

  "response": {
    "order_id_path":     "order.id",
    "order_status_path": "order.status",
    "positions_path":    "positions.position",
    "quote_list_path":   "quotes.quote",
    "quote_symbol_field":"symbol",
    "quote_price_field": "last",
    "balance": {
      "nav":          "balances.total_equity",
      "cash":         "balances.total_cash",
      "buying_power": "balances.total_cash"
    },
    "position_fields": {
      "qty":             "quantity",
      "avg_entry_price": "cost_basis",
      "symbol":          "symbol"
    }
  },

  "value_maps": {
    "side":          { "buy": "buy", "sell": "sell" },
    "time_in_force": { "day": "day", "gtc": "gtc" }
  },

  "capabilities": {
    "fractional_shares":    false,
    "asset_classes":        ["us_equity"],
    "order_types":          ["market", "limit", "stop", "stop_limit"],
    "time_in_force":        ["day", "gtc"],
    "extended_hours":       false,
    "min_order_value_usd":  0.0,
    "commission_per_trade": 0.0
  },

  "market": {
    "timezone":   "America/New_York",
    "open_time":  "09:30",
    "close_time": "16:00",
    "currency":   "USD"
  },

  "rate_limits": {
    "requests_per_minute": 120,
    "orders_per_second":   5
  }
}
